---
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<section id="blog" class="px-6 py-20 md:py-24 border-t border-border">
  <div class="max-w-4xl w-full mx-auto">
    <h2 class="mb-12">Writing</h2>
    {posts.length === 0 ? (
      <p class="text-muted-foreground">No posts yet.</p>
    ) : (
      <div class="space-y-10">
        {posts.map((post) => {
          const formattedDate = post.data.date.toLocaleDateString('en-US', {
            year: 'numeric',
            month: 'long',
          });
          return (
            <article class="group">
              <a href={`/blog/${post.slug}`} class="block">
                <div class="mb-2">
                  <h3 class="group-hover:text-muted-foreground transition-colors">{post.data.title}</h3>
                  <time class="text-muted-foreground text-sm">{formattedDate}</time>
                </div>
                <p class="text-muted-foreground">{post.data.excerpt}</p>
              </a>
            </article>
          );
        })}
      </div>
    )}
  </div>
</section>
