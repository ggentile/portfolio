---
import { ClientRouter } from 'astro:transitions';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Portfolio',
  description = 'Art + Tech = <3 — creating digital experiences that blend thoughtful design with clean code.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/portfolio.png" />
    <ClientRouter />
    <script is:inline>
      function applyTheme() {
        try {
          const savedTheme = localStorage.getItem('theme');
          const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          const shouldUseDark = savedTheme === 'dark' || (!savedTheme && prefersDark);
          document.documentElement.classList.toggle('dark', shouldUseDark);
        } catch {
          // Keep default light theme if storage or media query access fails.
        }
      }
      applyTheme();
      document.addEventListener('astro:after-swap', applyTheme);
    </script>
  </head>
  <body class="bg-background text-foreground">
    <slot />
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
