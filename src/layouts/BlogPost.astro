---
import Layout from './Layout.astro';
import Footer from '../components/Footer.astro';
import Navigation from '../components/Navigation.astro';

interface Props {
  title: string;
  date: Date;
  excerpt: string;
}

const { title, date, excerpt } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
});
---

<Layout title={`${title} | Gianni Gentile`} description={excerpt}>
  <div class="flex w-full min-h-screen relative bg-background">
    <!-- Sidebar (desktop) -->
    <div class="hidden md:flex w-1/4 fixed h-screen flex-col justify-between border-r border-border pl-8 pr-4 py-12">
      <Navigation />
      <Footer />
    </div>

    <!-- Main content -->
    <div class="w-full md:w-3/4 md:ml-[25%] flex flex-col">
      <!-- Mobile nav -->
      <div class="md:hidden p-6 border-b border-border">
        <Navigation />
      </div>

      <article class="px-6 py-24 max-w-4xl">
        <a
          href="/#blog"
          class="text-muted-foreground hover:text-foreground transition-colors text-sm mb-12 inline-block"
        >
          ← Back
        </a>
        <header class="mb-12">
          <h1 class="mb-4">{title}</h1>
          <time class="text-muted-foreground">{formattedDate}</time>
        </header>
        <div class="prose">
          <slot />
        </div>
      </article>

      <!-- Mobile footer -->
      <div class="md:hidden p-6 mt-auto border-t border-border">
        <Footer />
      </div>
    </div>
  </div>
</Layout>
